
<!--
  Manipulator specific version of 'robot_interface_streaming.launch'.

  Defaults provided for mini:
   - 6 joints

  Usage:
    robot_interface_streaming_motomini.launch robot_ip:=<value> controller:=<yrc1000>
-->
<launch>

  <arg name="robot_ip" />

  <!-- controller: Controller name (yrc1000) -->
  <arg name="controller"/>
  
  <remap from="/joint_states" to="/motomini_joint_states" />

  <include file="$(find motoman_motomini_support)/launch/load_motomini.launch" />

  <rosparam command="load" file="$(find motoman_motomini_support)/config/joint_names_motomini.yaml" />

  <include file="$(find motoman_driver)/launch/robot_interface_streaming_$(arg controller).launch">
    <arg name="robot_ip"   value="$(arg robot_ip)" />
  </include>
</launch>
