# --- ROS 1 & ROS 2 Build Artifacts ---
build/
install/
devel/
log/
.catkin_workspace
.catkin_tools

# --- ROS Generated Files ---
# These are often generated inside src packages during compilation
*.msg.h
*.srv.h
msg_gen/
srv_gen/
msg/*Action.msg
msg/*ActionGoal.msg
msg/*ActionResult.msg
msg/*ActionFeedback.msg

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# --- C++ ---
*.o
*.obj
*.so
*.a
*.lib
*.dylib

# --- IDE & Editor Configs (Optional but recommended) ---
.vscode/
.idea/
*.swp
*~
.DS_Store

# --- Private Keys / Secrets (Safety net) ---
*.pem
*.key
id_rsa